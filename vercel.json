{
  "routes": [
    {
      "src": "/portal",
      "dest": "/contractorbidprep/portal/subscriber/index.html"
    },
    {
      "src": "/portal/templates",
      "dest": "/contractorbidprep/portal/subscriber/templates.html"
    },
    {
      "src": "/portal/market-intel",
      "dest": "/contractorbidprep/portal/subscriber/market-intel.html"
    },
    {
      "src": "/portal/how-tos",
      "dest": "/contractorbidprep/portal/subscriber/how-tos.html"
    },
    {
      "src": "/portal/contacts",
      "dest": "/contractorbidprep/portal/subscriber/contacts.html"
    },
    {
      "src": "/portal/opportunities",
      "dest": "/contractorbidprep/portal/subscriber/opportunities.html"
    },
    {
      "src": "/portal/upgrade",
      "dest": "/contractorbidprep/portal/subscriber/upgrade.html"
    },
    {
      "src": "/portal/(.*)",
      "dest": "/portal/bid-portal.html"
    },
    {
      "src": "/",
      "has": [{ "type": "host", "value": "contractorbidprep.com" }],
      "dest": "/contractorbidprep/index.html"
    },
    {
      "src": "/((?!contractorbidprep|assets|css|js|portal).*)",
      "has": [{ "type": "host", "value": "contractorbidprep.com" }],
      "dest": "/contractorbidprep/$1"
    },
    {
      "src": "/",
      "dest": "/contractorbidprep/index.html"
    },
    {
      "src": "/((?!contractorbidprep|assets|css|js|portal).*)",
      "dest": "/contractorbidprep/$1"
    }
  ]
}
