{
  "routes": [
    {
      "src": "/portal/(.*)",
      "dest": "/contractorbidprep/portal/bid-portal.html"
    },
    {
      "src": "/",
      "has": [{ "type": "host", "value": "contractorbidprep.com" }],
      "dest": "/contractorbidprep/index.html"
    },
    {
      "src": "/((?!contractorbidprep|assets|css|js|portal).*)",
      "has": [{ "type": "host", "value": "contractorbidprep.com" }],
      "dest": "/contractorbidprep/$1"
    },
    {
      "src": "/",
      "dest": "/contractorbidprep/index.html"
    },
    {
      "src": "/((?!contractorbidprep|assets|css|js|portal).*)",
      "dest": "/contractorbidprep/$1"
    }
  ]
}
